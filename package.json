{
  "name": "claude-config-studio",
  "version": "0.1.0",
  "description": "Desktop application for managing Claude Code .claude/ configuration folders",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathPattern=tests/unit",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "playwright test",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chokidar": "^3.6.0",
    "electron-log": "^5.2.0",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "keytar": "^7.9.0",
    "proper-lockfile": "^4.1.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
